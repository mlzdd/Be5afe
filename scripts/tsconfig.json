{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "baseUrl": "..",
    "paths": {
      "@products/*": ["src/products/*"],
      "@shared/*": ["src/shared/*"],
      "@modules/*": ["src/modules/*"]
    }
  },
  "include": ["*.ts", "../src/products/**/*.ts", "../src/shared/**/*.ts", "../src/modules/**/*.ts"]
}
